# Copy to .env for local dev, or set these in Netlify → Site configuration →
# Environment variables for production. All VITE_ vars are baked in at BUILD
# time — after changing them on Netlify you must trigger a new deploy.

# Backend API URL. Leave empty locally (Vite proxies /api to localhost:4000).
VITE_API_URL=

# Google Analytics 4 Measurement ID (starts with "G-"). Leave empty to disable.
VITE_GA_MEASUREMENT_ID=

# Meta (Facebook/Instagram) Pixel ID. Leave empty to disable.
VITE_META_PIXEL_ID=
