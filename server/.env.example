# Copy to server/.env and fill in. NEVER commit the real .env.
DATABASE_URL="file:./dev.db"
JWT_SECRET=
PORT=4000
NODE_ENV=development

# Public URLs
API_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173
SITE_URL=http://localhost:5173

# Email — SendGrid (HTTP API, not SMTP — some hosts block outbound SMTP ports)
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=
FROM_NAME="JD Academy"

# Error monitoring — leave empty locally to disable
SENTRY_DSN=

# Platform fees (%)
PLATFORM_FEE_STUDENT=5
PLATFORM_FEE_TEACHER_PUBLISH=10
PLATFORM_FEE_LIVE=7

# --- Integrations (add when ready; routes stay disabled until set) ---
# Daily.co / Jitsi live sessions currently need no key (Jitsi is free)
# Stripe payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Generate a strong JWT secret:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
