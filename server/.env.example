# Copy to server/.env and fill in. NEVER commit the real .env.
DATABASE_URL="file:./dev.db"
JWT_SECRET=
PORT=4000

# Public URLs
API_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173
SITE_URL=http://localhost:5173

# Email — Gmail SMTP (app password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
FROM_NAME="JD Learn"

# Platform fees (%)
PLATFORM_FEE_STUDENT=5
PLATFORM_FEE_TEACHER_PUBLISH=10
PLATFORM_FEE_LIVE=7

# --- Integrations (add when ready; routes stay disabled until set) ---
# Mux video
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
# Daily.co live
DAILY_API_KEY=
# Stripe payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Cloudflare R2 files
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

NODE_ENV=development

# Generate a strong JWT secret:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
